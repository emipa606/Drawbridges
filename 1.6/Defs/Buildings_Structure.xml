  </ThingDef>
  <ThingDef ParentName="DrawbridgeAbstract" Name="DrawbridgeBaseBig">
    <defName>DrawbridgeBig</defName>
    <label>drawbridge (5x6)</label>
    <description>A mechanical drawbridge that spans 5x6 tiles. Constructed for both defense and accessibility, this drawbridge can be raised or lowered to control passage over obstacles such as moats. Ideal for strategic fortification, it serves as a reliable barrier against intruders when raised and allows effortless traversal when lowered.</description>
    <statBases>
      <WorkToBuild>6000</WorkToBuild>
      <MaxHitPoints>1000</MaxHitPoints>
      <Flammability>0</Flammability>
    </statBases>
    <size>(5, 6)</size>
    <graphicData>
      <texPath>Drawbridges/5x6_ground</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(10,10)</drawSize>
      <damageData>
        <enabled>false</enabled>
      </damageData>
    </graphicData>
    <uiIconPath>Drawbridges/5x6_Menu</uiIconPath>
    <costList>
      <Steel>200</Steel>
    </costList>
