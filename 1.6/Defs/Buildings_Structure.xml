<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <DesignatorDropdownGroupDef>
    <defName>Drawbridges</defName>
    <label>Drawbridges</label>
  </DesignatorDropdownGroupDef>
  <ThingDef ParentName="BuildingBase" Name="DrawbridgeAbstract" Abstract="True">
    <category>Building</category>
    <altitudeLayer>BuildingOnTop</altitudeLayer>
    <fillPercent>1</fillPercent>
    <useHitPoints>true</useHitPoints>
    <leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
    <selectable>true</selectable>
    <tickerType>Normal</tickerType>
    <rotatable>True</rotatable>
    <soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
    <designatorDropdown>Drawbridges</designatorDropdown>
    <designationCategory>Structure</designationCategory>
    <designationHotKey>Misc2</designationHotKey>
    <drawerType>RealtimeOnly</drawerType>
    <thingClass>Drawbridges.Drawbridge</thingClass>
    <passability>PassThroughOnly</passability>
    <terrainAffordanceNeeded IsNull="True">
    </terrainAffordanceNeeded>
    <building>
      <isInert>true</isInert>
      <ai_chillDestination>false</ai_chillDestination>
    </building>
  </ThingDef>
  <ThingDef ParentName="DrawbridgeAbstract" Name="DrawbridgeBaseSmall">
    <defName>DrawbridgeSmall</defName>
    <label>drawbridge (2x6)</label>
    <description>A durable drawbridge that covers a 2x6 area and can be raised or lowered to control access across a gap or moat. Made from sturdy materials, it provides defense by preventing or allowing passage when needed. Ideal for fortifying settlements while maintaining controlled entry points.</description>
    <statBases>
      <WorkToBuild>4000</WorkToBuild>
      <MaxHitPoints>640</MaxHitPoints>
      <Flammability>0</Flammability>
    </statBases>
    <size>(2, 6)</size>
    <graphicData>
      <texPath>Drawbridges/2x6_ground</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(8,10)</drawSize>
      <damageData>
        <enabled>false</enabled>
      </damageData>
    </graphicData>
    <uiIconPath>Drawbridges/2x6_Menu</uiIconPath>
    <costList>
      <Steel>100</Steel>
    </costList>
    <constructionSkillPrerequisite>6</constructionSkillPrerequisite>
  </ThingDef>
  <ThingDef ParentName="DrawbridgeBaseSmall">
    <defName>DrawbridgeSmallRaised</defName>
    <passability>PassThroughOnly</passability>
    <designationCategory IsNull="True" />
    <researchPrerequisites IsNull="True" />
    <blockLight>false</blockLight>
    <fillPercent>0</fillPercent>
    <graphicData>
      <texPath>Drawbridges/2x6</texPath>
    </graphicData>
  </ThingDef>
